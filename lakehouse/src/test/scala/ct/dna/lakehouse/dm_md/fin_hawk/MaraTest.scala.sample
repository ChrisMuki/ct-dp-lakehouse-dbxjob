package ct.dna.lakehouse.dm_md.fin_hawk

import ct.dna.lakehouse.core.testutils.TestDataManager
import ct.dna.lakehouse.core.testutils.TestForTable
import ct.dna.lakehouse.sr.ct_gbl_e32
import ct.dna.lakehouse.sr.ct_gbl_epp
import ct.dna.utils.ResourceLoader
import org.apache.spark.sql.SparkSession

/** End-to-end test for `ct.dna.lakehouse.dm_md.fin_hawk.mara`.
  *
  * Drives the full production path (`UpdatedTableProcessor.update(mara)` â†’ `mara.executeTransaction`) against real Delta tables on a local ephemeral Spark /
  * Hive metastore. Each phase mutates source tables via [[TestDataManager.syncToSource]], runs the update, and asserts the target contents against an Excel
  * sheet via [[TestDataManager.assertTargetMatches]].
  *
  * Coverage: the fixture enumerates 7 per-row transitions a single source row can undergo from one snapshot ("pre") to the next ("post"):
  *
  *   - Case 1: value v1 â†’ value v2
  *   - Case 2: value v1 â†’ NULL
  *   - Case 3: value v1 â†’ same v1 + alt column (`_mk_created_at`) differs
  *   - Case 4: value v1 â†’ row bit-identical (no CDF event)
  *   - Case 5: value v1 â†’ row deleted
  *   - Case 6: no row â†’ row with value
  *   - Case 7: no row â†’ row with NULL value column
  *
  * The fixture instantiates one matnr per case as `M{i:02}`. The case comment is carried in a leading `#case` column that `TestDataManager.read` drops on load.
  *
  * Only `mtart` (a column consumed by the merge) is varied. All other non-metadata columns stay NULL â€” `mara`'s source entity is `Joined[E_mara_part1,
  * E_mara_part2]` (267+ columns including decimal/binary), and `TestDataManager.read` does not support those cell types.
  *
  * Only two of the 14 source feeds are populated (`ct_gbl_e32.mara` and `ct_gbl_epp.mara`); the other 12 stay empty and contribute nothing (the framework
  * reports them as `isUnchanged` and skips them).
  *
  * Phases:
  *
  *   1. Phase 0 â€” every source and the target are empty. Running update must leave the target empty.
  *
  *   1. Phase 1 â€” `ct_gbl_e32.mara` and `ct_gbl_epp.mara` receive their "pre" snapshots. The framework still treats these feeds as CDF (known commit is the
  *      create-time commit from Phase 0), so every pre-present row arrives as a CDF insert. Both halves of the target are populated.
  *
  *   1. Phase 2 â€” only `ct_gbl_e32.mara` is `syncToSource`-aligned to its "post" snapshot. The preâ†’post diff drives a per-row CDF stream (insert / update /
  *      delete) covering every transition. EPP rows must remain bit-identical to phase 1.
  *
  *   1. Phase 3 â€” `ct_gbl_epp.mara` is dropped and re-created, then loaded with its "post" snapshot. Because the previously-recorded known commit no longer
  *      exists, `ChangeFeedImpl.isSnapshot` returns true. The snapshot branches of the merge are exercised: rows present in the snapshot overwrite the target,
  *      rows absent from the snapshot are deleted via `whenNotMatchedBySource` (gated on `_mk_system âˆˆ snapshotSystems`), and rows under non-snapshot systems
  *      (E32) must stay untouched.
  *
  * The xlsx is regenerated by `lakehouse/src/test/scripts/ct/dna/lakehouse/dm_md/fin_hawk/generate_mara_test_xlsx.py`, which also simulates the production
  * merge in Python to compute the expected target rows.
  */
class MaraTest extends TestForTable(mara) {

  lazy val tdm = TestDataManager("mara", "MaraTest.xlsx", ResourceLoader.withClass(mara.getClass))

  lazy val spark: SparkSession = SparkSession.active

  override protected def beforeAll(): Unit = {
    super.beforeAll()

    tdm.dropTargetIfExists(mara)
    mara.sourceTableSpecs.foreach(tdm.dropSourceIfExists)

    tdm.createAsTarget(mara)
    mara.sourceTableSpecs.foreach(tdm.createAsSource)
  }

  override protected def afterAll(): Unit = try {
    tdm.dropTargetIfExists(mara)
    mara.sourceTableSpecs.foreach(tdm.dropSourceIfExists)
  } finally super.afterAll()

  behavior of "mara"

  it should "validateToRoot" in {
    mara.validateToRoot()
  }

  // ---------------------------------------------------------------------------
  // Phase 0 â€” empty everywhere.
  // ---------------------------------------------------------------------------

  it should "Phase 0: leave the target empty when every source is empty" in {
    tdm.update(mara)
    tdm.assertTargetMatches(mara, "target_phase0")
  }

  // ---------------------------------------------------------------------------
  // Phase 1 â€” initial data in two of the fourteen sources.
  // ---------------------------------------------------------------------------

  it should "Phase 1: populate target from ct_gbl_e32 and ct_gbl_epp initial feeds" in {
    tdm.syncToSource(ct_gbl_e32.mara, "e32_phase1")
    tdm.syncToSource(ct_gbl_epp.mara, "epp_phase1")

    tdm.update(mara)

    tdm.assertTargetMatches(mara, "target_phase1")
  }

  // ---------------------------------------------------------------------------
  // Phase 2 â€” case matrix on ct_gbl_e32 (EPP must stay intact).
  // ---------------------------------------------------------------------------

  it should "Phase 2: apply CDF inserts/updates/deletes from ct_gbl_e32 without touching EPP rows" in {
    tdm.syncToSource(ct_gbl_e32.mara, "e32_phase2")

    tdm.update(mara)

    tdm.assertTargetMatches(mara, "target_phase2")
  }

  // ---------------------------------------------------------------------------
  // Phase 3 â€” snapshot semantics for ct_gbl_epp.
  // ---------------------------------------------------------------------------

  it should "Phase 3: snapshot-rebuild ct_gbl_epp deletes absent EPP rows and leaves E32 rows untouched" in {
    tdm.dropSourceIfExists(ct_gbl_epp.mara)
    tdm.createAsSource(ct_gbl_epp.mara)
    tdm.syncToSource(ct_gbl_epp.mara, "epp_phase3")

    tdm.update(mara)

    tdm.assertTargetMatches(mara, "target_phase3")
  }
}
