http_proxy=http://cias.geoazure.conti.de:8080
https_proxy=http://cias.geoazure.conti.de:8080
HTTP_PROXY=http://cias.geoazure.conti.de:8080
HTTPS_PROXY=http://cias.geoazure.conti.de:8080
NO_PROXY=127.0.0.1,localhost,.conti.de,ct-ind.com,contiwan.com,dsf.contitech.de,169.254.169.254
JAVA_proxyHost=cias.geoazure.conti.de
JAVA_proxyPort=8080
JAVA_nonProxyHosts=127.0.0.1|localhost|*.conti.de|*.ct-ind.com|*.contiwan.com|*.dsf.contitech.de|169.254.169.254
JAVA_TOOL_OPTIONS=-Dhttp.proxyHost=cias.geoazure.conti.de -Dhttp.proxyPort=8080 -Dhttp.nonProxyHosts=127.0.0.1|localhost|*.conti.de|*.ct-ind.com|*.contiwan.com|*.dsf.contitech.de|169.254.169.254 -Dhttps.proxyHost=cias.geoazure.conti.de -Dhttps.proxyPort=8080 -Dhttps.nonProxyHosts=127.0.0.1|localhost|*.conti.de|*.ct-ind.com|*.contiwan.com|*.dsf.contitech.de|169.254.169.254 -Djava.net.useSystemProxies=true
COURSIER_OPTS=-J-Dhttp.proxyHost=cias.geoazure.conti.de -J-Dhttp.proxyPort=8080 -J-Dhttp.nonProxyHosts=127.0.0.1|localhost|*.conti.de|*.ct-ind.com|*.contiwan.com|*.dsf.contitech.de|169.254.169.254 -J-Dhttps.proxyHost=cias.geoazure.conti.de -J-Dhttps.proxyPort=8080 -J-Dhttps.nonProxyHosts=127.0.0.1|localhost|*.conti.de|*.ct-ind.com|*.contiwan.com|*.dsf.contitech.de|169.254.169.254 -J-Djava.net.useSystemProxies=true
