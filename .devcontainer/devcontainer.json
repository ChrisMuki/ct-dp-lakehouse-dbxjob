{
  "name": "DnA_17",
  "image": "ctdsfacr.azurecr.io/devcontainer/full:latest",
  "runArgs": [
    "--env-file",
    ".devcontainer/used.env"
  ],
  "containerUser": "vscode",
  "updateRemoteUserUID": true,
  "initializeCommand": "/bin/bash -lc 'set -euo pipefail; if [ -f .devcontainer/custom.env ]; then cp -f .devcontainer/custom.env .devcontainer/used.env; else cp -f .devcontainer/default.env .devcontainer/used.env; fi'",
  "mounts": [
    "type=bind,source=${env:HOME},target=/home/vscode/host.home"
  ],
  "postCreateCommand": "/bin/bash .devcontainer/postCreateCommand.sh",
  "customizations": {
    "vscode": {
      "settings": {
        // "terminal.integrated.defaultProfile.linux": "zsh",
        "metals.javaVersion": "17",
        "metals.fallbackScalaVersion": "2.13.16",
        "metals.serverProperties": [
          "-Xmx2G",
          "-XX:+UseZGC",
          "-XX:ZUncommitDelay=30",
          "-XX:ZCollectionInterval=5",
          "-XX:+IgnoreUnrecognizedVMOptions",
          "--add-opens=java.base/java.nio=ALL-UNNAMED",
          "--add-opens=java.base/java.net=ALL-UNNAMED",
          "--add-opens=java.base/java.lang=ALL-UNNAMED",
          "--add-opens=java.base/java.util=ALL-UNNAMED",
          "--add-opens=java.base/java.util=ALL-UNNAMED",
          "--add-opens=java.base/java.lang.reflect=ALL-UNNAMED",
          "--add-opens=java.base/sun.util.calendar=ALL-UNNAMED",
          "-Djava.net.useSystemProxies=true"
        ]
      },
      "extensions": [
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "ms-vscode.azurecli",
        "scalameta.metals@1.59.0",
        "mhutchie.git-graph"
      ]
    }
  }
}