{
  "name": "Lakehouse",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--env-file",
    ".devcontainer/.proxy.env"
  ],
  "initializeCommand": "bash .devcontainer/scripts/gen_proxy_env.sh .devcontainer/.proxy.env",
  "containerUser": "vscode",
  "updateRemoteUserUID": true,
  "mounts": [
    "type=bind,source=${env:HOME}/.gitconfig,target=/home/vscode/.gitconfig",
    "type=bind,source=${env:HOME}/.sbt/.credentials,target=/home/vscode/.sbt/.credentials"
  ],
  "postCreateCommand": "/bin/bash .devcontainer/postCreateCommand.sh",
  "customizations": {
    "vscode": {
      "settings": {
        // "terminal.integrated.defaultProfile.linux": "zsh",
        "metals.javaVersion": "17",
        "metals.fallbackScalaVersion": "2.13.16",
        "metals.serverProperties": [
          "-Xmx2G",
          "-XX:+UseZGC",
          "-XX:ZUncommitDelay=30",
          "-XX:ZCollectionInterval=5",
          "-XX:+IgnoreUnrecognizedVMOptions",
          "--add-opens=java.base/java.nio=ALL-UNNAMED",
          "--add-opens=java.base/java.net=ALL-UNNAMED",
          "--add-opens=java.base/java.lang=ALL-UNNAMED",
          "--add-opens=java.base/java.util=ALL-UNNAMED",
          "--add-opens=java.base/java.util=ALL-UNNAMED",
          "--add-opens=java.base/java.lang.reflect=ALL-UNNAMED",
          "--add-opens=java.base/sun.util.calendar=ALL-UNNAMED"
        ]
      },
      "extensions": [
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "ms-vscode.azurecli",
        "scalameta.metals@1.59.0",
        "mhutchie.git-graph"
      ]
    }
  }
}