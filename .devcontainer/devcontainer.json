{
  "name": "DNA",
  "image": "common-docker-r.artifactory.geo.conti.de/ubuntu:22.04",
  "overrideFeatureInstallOrder": [
    "./features/conti-ca-certificates",
    "ghcr.io/devcontainers/features/common-utils",
    "./features/dataplatform"
    // ,    "./features/zsh-hints"
  ],
  "features": {
    "./features/conti-ca-certificates": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installGit": true,
      "configureZshAsDefaultShell": true,
      "username": "dnadev"
    },
    "./features/dataplatform": {}
    // ,    "./features/zsh-hints": {}
  },
  "remoteUser": "dnadev",
  "customizations": {
    "vscode": {
      "extensions": [
        "scalameta.metals",
        "mhutchie.git-graph"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "metals.javaVersion": "17",
        "metals.fallbackScalaVersion": "2.13.16",
        "metals.serverProperties": [
          "-Xmx2G",
          "-XX:+UseZGC",
          "-XX:ZUncommitDelay=30",
          "-XX:ZCollectionInterval=5",
          "-XX:+IgnoreUnrecognizedVMOptions",
          "--add-opens=java.base/java.nio=ALL-UNNAMED",
          "--add-opens=java.base/java.net=ALL-UNNAMED",
          "--add-opens=java.base/java.lang=ALL-UNNAMED",
          "--add-opens=java.base/java.util=ALL-UNNAMED",
          "--add-opens=java.base/java.util=ALL-UNNAMED",
          "--add-opens=java.base/java.lang.reflect=ALL-UNNAMED",
          "--add-opens=java.base/sun.util.calendar=ALL-UNNAMED"
        ]
      }
    }
  },
  "postCreateCommand": "zsh ./.devcontainer/postCreateCommand.zsh",
  "mounts": [
    "source=${localEnv:HOME}/,target=/mnt/host.home/,type=bind"
  ]
}