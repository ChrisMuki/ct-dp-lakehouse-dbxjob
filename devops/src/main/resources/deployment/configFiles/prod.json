{
  "deploymentConfig": {
    "host": "https://adb-7405608343332957.17.azuredatabricks.net",
    "volumeCatalog": "lakehouse",
    "volumeSchema": "sp_1043_edap_prod_dbxjob_lakehouse",
    "targetMode": "production",
    "deploymentAzAuth": "AzureCli",
    "clusterConfiguration": {
      "sparkVersion": "17.3.x-scala2.13",
      "clusterPolicyId": "0009D8E7AF32CDAF",
      "maxWorkerNodes": 8,
      "nodeTypeId": "Standard_D4ds_v5",
      "driverNodeTypeId": "Standard_E8ds_v5",
      "sparkConf": {
        "spark.databricks.queryTagging.enabled": "false",
        "spark.databricks.aggressiveWindowDownS": "1200",
        "spark.sql.shuffle.partitions": "200",
        "spark.databricks.delta.merge.enableLowShuffleMerge": "true",
        "spark.sql.autoBroadcastJoinThreshold": "104857600",
        "spark.sql.adaptive.autoBroadcastJoinThreshold": "104857600",
        "spark.scheduler.mode": "FAIR",
        "spark.sql.adaptive.enabled": "true",
        "spark.sql.adaptive.coalescePartitions.enabled": "true",
        "spark.sql.adaptive.coalescePartitions.minPartitionSize": "16MB",
        "spark.sql.adaptive.advisoryPartitionSizeInBytes": "128MB",
        "spark.sql.adaptive.coalescePartitions.initialPartitionNum": "512"
      }
    },
    "_comment_clusterConfigurations": "Per-catalog overrides on top of clusterConfiguration. Each field optional; absent fields inherit the global value. sparkConf is shallow-merged (per-catalog wins).",
    "clusterConfigurations": {
      "sr": {
        "_comment": "Many small SR tables (1:1 from SR_RAW). 8 x D8ds_v5 = 64 cores at max scale. With taskParallelism.sr=4 each concurrent table gets ~16 cores at max, reducing driver/event pressure while keeping enough MERGE fan-out.",
        "nodeTypeId": "Standard_D8ds_v5",
        "driverNodeTypeId": "Standard_E16ds_v5",
        "maxWorkerNodes": 8,
        "sparkConf": {
          "spark.sql.shuffle.partitions": "256",
          "spark.databricks.delta.merge.materializeSource": "none"
        }
      },
      "dm_md": {
        "_comment": "Few large DM/MD tables. Deep+fat memory-optimized executors; smaller driver since fewer concurrent worker JVMs.",
        "nodeTypeId": "Standard_E4ds_v5",
        "driverNodeTypeId": "Standard_D4ds_v5",
        "maxWorkerNodes": 4,
        "sparkConf": {
          "spark.sql.shuffle.partitions": "800"
        }
      },
      "dw_tx": {
        "_comment": "DW_TX initial profile mirrors dm_md (deep+fat). Tune once the layer has tables and a workload signature.",
        "nodeTypeId": "Standard_E4ds_v5",
        "driverNodeTypeId": "Standard_D4ds_v5",
        "maxWorkerNodes": 4,
        "sparkConf": {
          "spark.sql.shuffle.partitions": "800"
        }
      }
    },
    "permissions": [
      {
        "groupName": "au00_1043_EDAP_prod_DevOps",
        "level": "CAN_RUN"
      }
    ],
    "schedules": {
      "sr": {
        "quartzCronExpression": "0 0 2 * * ?",
        "timezoneId": "UTC",
        "pauseStatus": "UNPAUSED"
      },
      "dm_md": {
        "quartzCronExpression": "0 0 4 * * ?",
        "timezoneId": "UTC",
        "pauseStatus": "UNPAUSED"
      },
      "dw_tx": {
        "quartzCronExpression": "0 0 3 * * ?",
        "timezoneId": "UTC",
        "pauseStatus": "UNPAUSED"
      }
    },
    "continuous": {},
    "taskParallelismDefault": 4,
    "taskParallelism": {
      "sr": 4,
      "dm_md": 4,
      "dw_tx": 4
    },
    "monitoring": {
      "idleSleepSeconds": 5,
      "statusIntervalSeconds": 60
    }
  }
}
